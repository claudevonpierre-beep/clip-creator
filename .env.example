# ── Required ──────────────────────────────────────────────────────────────────
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_64_char_hex

# Team access code — change this to something stronger
TOOL_PASSWORD=33rdclips2026

# ── Railway: Persistent Volume ─────────────────────────────────────────────────
# Set this to your Railway volume mount path (e.g. /data)
# Railway will mount the volume here; SQLite DB + uploads will live inside it
DATA_DIR=/data

# ── Optional: Google OAuth ─────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_secret
# ADMIN_EMAIL=you@yourcompany.com

# ── Optional: AssemblyAI (server-side key — or leave blank, users enter their own) ──
# ASSEMBLYAI_KEY=your_key_here
